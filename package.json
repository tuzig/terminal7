{
    "name": "Terminal7",
    "version": "1.11.2",
    "description": "A touchable terminal emulator & multiplexer tablet app",
    "main": "src/index.js",
    "homepage": "https://terminal7.dev",
    "private": true,
    "build": {
        "appId": "dev.terminal7",
        "files": [
            "index.html",
            "css/*"
        ],
        "directories": {
            "buildResources": "resources"
        },
        "publish": null
    },
    "dependencies": {
        "@capacitor-community/native-audio": "^8.0.0",
        "@capacitor/android": "^8.0.0",
        "@capacitor/app": "^8.0.0",
        "@capacitor/browser": "^8.0.0",
        "@capacitor/camera": "^8.0.0",
        "@capacitor/cli": "^8.0.0",
        "@capacitor/clipboard": "^8.0.0",
        "@capacitor/core": "^8.0.0",
        "@capacitor/device": "^8.0.0",
        "@capacitor/filesystem": "^8.0.0",
        "@capacitor/ios": "^8.0.0",
        "@capacitor/keyboard": "^8.0.0",
        "@capacitor/network": "^8.0.0",
        "@capacitor/preferences": "^8.0.0",
        "@capacitor/status-bar": "^8.0.0",
        "@revenuecat/purchases-capacitor": "^12.0.0",
        "@tuzig/codemirror": "5.65.5-mods",
        "@tuzig/toml": "^3.0.0-browser",
        "@types/marked": "^4.0.7",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/addon-image": "^0.9.0",
        "@xterm/addon-search": "^0.16.0",
        "@xterm/addon-web-links": "^0.12.0",
        "@xterm/addon-webgl": "^0.19.0",
        "@xterm/xterm": "^6.0.0",
        "bowser": "^2.11.0",
        "capacitor-native-biometric": "4.2.2",
        "capacitor-rate-app": "4.0.3",
        "capacitor-ssh-plugin": "0.5.4",
        "ed25519-keygen": "^0.2.4",
        "fontfaceobserver": "^2.3.0",
        "glob": "<8",
        "idb": "7.1.1",
        "interactjs": "^1.10.27",
        "marked": "^4.1.0",
        "uuid": "^14.0.0",
        "vite": "^7.3.5"
    },
    "devDependencies": {
        "@capacitor/assets": "^3.0.5",
        "@interactjs/types": "^1.10.27",
        "@playwright/test": "^1.20.1",
        "@typescript-eslint/eslint-plugin": "^8.39.0",
        "@typescript-eslint/parser": "^8.39.0",
        "eslint": "^8.57.1",
        "interactjs": "^1.10.27",
        "jsdom": "^19.0.0",
        "native-run": "^1.7.4",
        "prettier": "^3.8.3",
        "typescript": "^5.0.0",
        "vi-canvas-mock": "^1.0.0",
        "vite-plugin-pwa": "^1.0.0",
        "vitest": "^4.0.0",
        "workbox-build": "^7.0.0",
        "workbox-window": "^7.0.0",
        "yarn": "^1.22.17"
    },
    "resolutions": {
        "@capacitor/assets/@capacitor/cli": "^8.0.0",
        "tmp": "^0.2.6",
        "minimatch": "^3.1.4",
        "@capacitor/assets/@trapezedev/project/xcode/uuid": "^11.1.1",
        "vite": "^7.3.5"
    },
    "scripts": {
        "start": "npm run dev",
        "dev": "vite",
        "stage": "vite build --sourcemap && vite preview",
        "run": "vite build -c vite.dev.config.js && cap run ios",
        "runa": "vite build -c vite.dev.config.js && cap run android",
        "test": "vitest run && ./aatp/run",
        "build": "vite build -c vite.dev.config.js",
        "build:ios": "vite build -c vite.dev.config.js && cap build ios",
        "build:android": "vite build -c vite.dev.config.js && cap build android",
        "run:ios": "vite build -c vite.dev.config.js && cap run ios",
        "run:android": "vite build -c vite.dev.config.js && cap run android",
        "clean": "rm -rf dist ios/App/App/public/*",
        "aatp": "bash ./aatp/run",
        "lint": "eslint aatp src --ext .js,.ts && tsc --noEmit",
        "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tuzig/terminal7.git"
    },
    "keywords": [
        "terminal",
        "tmux",
        "webrtc"
    ],
    "author": "Benny Daon",
    "license": "GPL-3.0-only",
    "bugs": {
        "url": "https://github.com/tuzig/terminal7/issues"
    }
}
